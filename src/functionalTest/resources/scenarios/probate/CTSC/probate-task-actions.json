{
  "description": "probate create ExamineDigitalCaseProbate task Actions",
  "enabled": true,
  "jurisdiction": "PROBATE",
  "caseType": "GrantOfRepresentation",
  "options": {
    "taskRetrievalApi": "task-management-api"
  },
  "required": {
    "credentials": {
      "key": "systemupdate"
    },
    "ccd": [
      {
        "eventId": "applyforGrantPaperApplicationMan",
        "caseData": {
          "template": "minimal-probate.json",
          "replacements": {
          }
        }
      }
    ]
  },
  "before": {
    "request": {
      "credentials": {
        "key": "caseworker"
      },
      "input": {
        "eventMessages": [
          {
            "destination": "RestEndpoint",
            "template": "minimal-ccd-event-message-probate.json",
            "replacements": {
              "EventId": "handleEvidence",
              "NewStateId": "CasePrinted"
            }
          }
        ]
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator"
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-probate.json",
          "replacements": {
            "tasks": [
              {
                "task_state": "unassigned",
                "task_system": "SELF",
                "test_meta_data": [
                  {
                    "key": "role_data_reference",
                    "value": "ExamineDigitalCaseProbate"
                  }
                ],
                "type": "ExamineDigitalCaseProbate",
                "name": "Examine Digital Case - Probate",
                "minor_priority": 500,
                "major_priority": 5000,
                "description": "[Select For QA](/cases/case-details/${[CASE_REFERENCE]}/trigger/boSelectForQA)"
              }
            ]
          }
        }
      }
    ]
  },
  "test": {
    "request": {
      "type": "CLAIM",
      "credentials": {
        "key": "caseworker",
        "granularPermission": true
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator",
          "granularPermission": true
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-probate.json",
          "replacements": {
            "tasks": [
              {
                "task_state": "assigned",
                "task_system": "SELF",
                "test_meta_data": [
                  {
                    "key": "role_data_reference",
                    "value": "ExamineDigitalCaseProbate"
                  }
                ],
                "type": "ExamineDigitalCaseProbate",
                "name": "Examine Digital Case - Probate",
                "minor_priority": 500,
                "major_priority": 5000,
                "description": "[Select For QA](/cases/case-details/${[CASE_REFERENCE]}/trigger/boSelectForQA)"
              }
            ]
          }
        }
      }
    ]
  }
}
